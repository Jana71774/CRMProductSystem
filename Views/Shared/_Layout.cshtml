<!DOCTYPE html>
<html>
<head>
    <title>CRM System</title>

    <!-- Syncfusion -->
    <link href="https://cdn.syncfusion.com/ej2/25.1.35/material.css" rel="stylesheet" />
    <script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #0a0a0a, #215c2f);
        }

        /* Sidebar */
        .sidebar {
            width: 230px;
            height: 100vh;
            position: fixed;
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(15px);
            color: white;
            padding-top: 20px;
        }

        .sidebar h3 {
            text-align: center;
            margin-bottom: 20px;
        }

        .sidebar a {
            display: block;
            padding: 12px;
            margin: 6px 12px;
            border-radius: 10px;
            color: white;
            text-decoration: none;
            transition: 0.3s;
        }

        .sidebar a:hover {
            background: rgba(255,255,255,0.2);
            transform: translateX(6px);
        }

        /* Content */
        .content {
            margin-left: 240px;
            padding: 20px;
        }

        /* Glass UI */
        .glass {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.2);
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
            color: white;
        }

        /* Cards */
        .card-modern {
            padding: 20px;
            border-radius: 16px;
            background: rgba(255,255,255,0.1);
            color: white;
            transition: 0.3s;
        }

        .card-modern:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        }

        /* Topbar */
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
    </style>
</head>

<body>

@{
    var role = Context.Session.GetString("Role");
}

<!-- Sidebar -->
<div class="sidebar">
    <h3>CRM</h3>

    @if (role == "Admin")
    {
        <a href="/Dashboard/AdminDashboard"><i class="fa fa-chart-line"></i> Dashboard</a>
        <a href="/Task/Index"><i class="fa fa-tasks"></i> Tasks</a>
        <a href="/User/Index"><i class="fa fa-users"></i> Users</a>
        <a href="/Product/Index"><i class="fa fa-box"></i> Products</a>
        <a href="/Followup/Index"><i class="fa fa-bell"></i> My Followups</a>
        <a href="/Customer/Index"><i class="fa fa-user"></i> Customers</a>
        <a href="/Order/Index"><i class="fa fa-shopping-cart"></i> Orders</a>
        <a href="/Reports/SalesReport"><i class="fa fa-file-alt"></i> Sales Report</a>
    }
    else if (role == "Employee")
    {
        <a href="/Dashboard/EmployeeDashboard"><i class="fa fa-home"></i> My Dashboard</a>
        <a href="/Task/MyTasks"><i class="fa fa-tasks"></i> My Tasks</a>
        <a href="/Followup/Index"><i class="fa fa-bell"></i> My Followups</a>
        <a href="/Order/Index"><i class="fa fa-shopping-cart"></i> Orders</a>

    }

    <a href="/Auth/Logout"><i class="fa fa-sign-out-alt"></i> Logout</a>
</div>

<!-- Content -->
<div class="content">

    <!-- Topbar -->
    <div class="glass p-3 mb-4 topbar">
        <h4>CRM Dashboard</h4>
        <span>Welcome, @Context.Session.GetString("Username") </span>
    </div>

    <!-- Body -->
    <div class="glass p-4">
        @RenderBody()
    </div>

</div>

<ejs-scripts></ejs-scripts>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@RenderSection("Scripts", required: false)

</body>
</html>